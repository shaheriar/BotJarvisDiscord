# Discord
DISCORD_TOKEN=your_bot_token
DISCORD_GUILD=your_guild_id
BOT_CLIENT_ID=your_discord_bot_client_id

# APIs
WEATHER_API_KEY=your_weatherapi_key
FINNHUB_API_KEY=your_finnhub_key
NEWS_API_KEY=your_newsapi_key
OPENAI_API_KEY=your_openai_key
# Which OpenAI model to use for Jarvis responses (chat + tool calling).
JARVIS_MODEL=gpt-4o-mini
# Optional: model to use for summarizing conversation history.
# If omitted, defaults to JARVIS_MODEL.
JARVIS_SUMMARY_MODEL=gpt-4o-mini
# Dedicated pass: synthesize one summary from all NewsAPI articles (defaults to JARVIS_MODEL).
JARVIS_NEWS_SUMMARY_MODEL=gpt-4o-mini
JARVIS_NEWS_SUMMARY_MAX_TOKENS=1000
# Lower = more deterministic citations (default 0.22).
JARVIS_NEWS_SUMMARY_TEMPERATURE=0.22
# NewsAPI page size before dedupe/rank; top five are sent to the model (default 20, max 100).
JARVIS_NEWS_FETCH_PAGE_SIZE=20
COINGECKO_API_KEY=your_coingecko_api_key
DEEPL_API_KEY=your_deepl_api_key

# Optional: comma-separated Discord user IDs that cannot use Jarvis
BANNED_USER_IDS=123456789,987654321

# Agent loop controls (Pi-friendly defaults)
JARVIS_MAX_AGENT_ITERATIONS=5
JARVIS_MAX_RESEARCH_CHARS=4000
JARVIS_SELF_CRITIQUE=false
JARVIS_MEMORY_DB_PATH=data/jarvis.db

# Web fetch controls
WEB_FETCH_MAX_CHARS=3000
WEB_FETCH_TIMEOUT=10
WEB_FETCH_MAX_BYTES=2000000
WEB_FETCH_DENYLIST=

# Optional heavy browser tool
BROWSER_ENABLED=false
PLAYWRIGHT_HEADLESS=true
